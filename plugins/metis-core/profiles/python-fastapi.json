{
  "name": "python-fastapi",
  "version": "0.1.0",
  "description": "Python project — FastAPI, Django, Flask, or general Python",
  "detect": {
    "files_any": ["pyproject.toml", "setup.py", "requirements.txt", "Pipfile"]
  },
  "capabilities": [
    "python"
  ],
  "optional_capabilities": [],
  "defaults": {
    "verify_command": "python -m py_compile",
    "test_command": "python -m pytest",
    "lint_command": "python -m ruff check",
    "src_dirs": ["src/", "app/"]
  },
  "makefile_targets": {
    "dev": { "command": "uvicorn app.main:app --reload", "description": "Start dev server with reload" },
    "test": { "command": "python -m pytest", "description": "Run test suite" },
    "lint": { "command": "python -m ruff check .", "description": "Lint source files" },
    "format": { "command": "python -m ruff format .", "description": "Format source files" },
    "typecheck": { "command": "python -m mypy .", "description": "Type check with mypy" },
    "check": { "command": "make typecheck && make lint && make test", "description": "Run all quality gates", "deps": ["typecheck", "lint", "test"] },
    "clean": { "command": "find . -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null; rm -rf .pytest_cache .mypy_cache .ruff_cache", "description": "Clean Python caches" },
    "migrate": { "command": "alembic upgrade head", "description": "Run database migrations" }
  },
  "questions": [
    {
      "key": "uses_mypy",
      "question": "Does this project use mypy for type checking?",
      "type": "boolean",
      "detect": "pyproject.toml:[tool.mypy]"
    }
  ]
}
