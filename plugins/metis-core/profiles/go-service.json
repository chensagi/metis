{
  "name": "go-service",
  "version": "0.1.0",
  "description": "Go project — services, CLIs, or libraries",
  "detect": {
    "files": ["go.mod"]
  },
  "capabilities": [
    "go"
  ],
  "optional_capabilities": [],
  "defaults": {
    "verify_command": "go build ./...",
    "test_command": "go test ./...",
    "lint_command": "golangci-lint run",
    "src_dirs": ["cmd/", "internal/", "pkg/"]
  },
  "makefile_targets": {
    "build": { "command": "go build ./...", "description": "Build all packages" },
    "run": { "command": "go run ./cmd/server", "description": "Run the service" },
    "test": { "command": "go test ./...", "description": "Run test suite" },
    "lint": { "command": "golangci-lint run", "description": "Lint source files" },
    "vet": { "command": "go vet ./...", "description": "Vet source files" },
    "fmt": { "command": "gofmt -w .", "description": "Format source files" },
    "check": { "command": "make vet && make lint && make test", "description": "Run all quality gates", "deps": ["vet", "lint", "test"] },
    "clean": { "command": "go clean ./...", "description": "Clean build cache" }
  },
  "questions": []
}
