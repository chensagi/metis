{
  "name": "typescript-node",
  "version": "0.1.0",
  "description": "TypeScript Node.js project — APIs, CLIs, or libraries",
  "detect": {
    "files": ["tsconfig.json", "package.json"],
    "not_files": ["app.json", "expo-env.d.ts"]
  },
  "capabilities": [
    "typescript"
  ],
  "optional_capabilities": [],
  "defaults": {
    "verify_command": "npx tsc --noEmit",
    "test_command": "npm test",
    "lint_command": "npx eslint",
    "src_dirs": ["src/"]
  },
  "makefile_targets": {
    "dev": { "command": "npx tsx watch src/index.ts", "description": "Start dev server with watch" },
    "build": { "command": "npx tsc", "description": "Build TypeScript" },
    "test": { "command": "npm test", "description": "Run test suite" },
    "typecheck": { "command": "npx tsc --noEmit", "description": "Type check without emitting" },
    "lint": { "command": "npx eslint src/", "description": "Lint source files" },
    "format": { "command": "npx prettier --write \"src/**/*.ts\"", "description": "Format source files" },
    "check": { "command": "make typecheck && make lint && make test", "description": "Run all quality gates", "deps": ["typecheck", "lint", "test"] },
    "clean": { "command": "rm -rf dist node_modules/.cache", "description": "Clean build artifacts" }
  },
  "questions": []
}
